{
  "name": "academico-product-line",
  "version": "1.0.0",
  "private": true,
  "description": "Fabrica y generador de la linea de productos del Sistema de Gestion Academica",
  "type": "module",
  "scripts": {
    "validate:domain": "node scripts/validate-domain.mjs",
    "generate": "node scripts/generate-product.mjs",
    "test": "node --test tests/*.test.mjs",
    "assets:sync": "node scripts/sync-assets.mjs",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=scripts/lib/*.mjs --test-coverage-lines=80 tests/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "yaml": "2.9.0"
  }
}
